{
  "manifest_version": 3,
  "name": "Hotmart Course Extractor (hotmart-dl)",
  "version": "3.1.3",
  "description": "Painel lateral pra escolher aulas, padrao de nome e qualidade, e exportar um course.json pra baixar com o hotmart-dl.",
  "permissions": ["activeTab", "scripting", "downloads", "sidePanel", "declarativeNetRequest"],
  "host_permissions": ["https://hotmart.com/*", "https://*.hotmart.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "hotmart_referer", "enabled": false, "path": "rules.json" }
    ]
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://hotmart.com/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": { "default_title": "hotmart-dl — abrir painel" },
  "side_panel": { "default_path": "popup.html" },
  "web_accessible_resources": [
    { "resources": ["extractor.js"], "matches": ["https://*.hotmart.com/*"] }
  ]
}
